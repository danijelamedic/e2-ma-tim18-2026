<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/step_by_step"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/timer"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvCurrentStep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/step_placeholder"
        android:textSize="16sp"
        android:gravity="center"
        android:background="#E0E0E0"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <TextView android:id="@+id/tvStep1" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#BDBDBD" android:layout_margin="4dp" android:text="1"/>
        <TextView android:id="@+id/tvStep2" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#BDBDBD" android:layout_margin="4dp" android:text="2"/>
        <TextView android:id="@+id/tvStep3" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#BDBDBD" android:layout_margin="4dp" android:text="3"/>
        <TextView android:id="@+id/tvStep4" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#BDBDBD" android:layout_margin="4dp" android:text="4"/>
        <TextView android:id="@+id/tvStep5" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#BDBDBD" android:layout_margin="4dp" android:text="5"/>
        <TextView android:id="@+id/tvStep6" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#BDBDBD" android:layout_margin="4dp" android:text="6"/>
        <TextView android:id="@+id/tvStep7" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:background="#BDBDBD" android:layout_margin="4dp" android:text="7"/>

    </LinearLayout>

    <EditText
        android:id="@+id/etAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_answer"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/confirm"/>

</LinearLayout>