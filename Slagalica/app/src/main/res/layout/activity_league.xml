<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4ECFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/back_icon"
                    android:textSize="24sp"
                    android:textColor="#2D1B5E"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="LEAGUES"
                    android:textColor="#2D1B5E"
                    android:textSize="26sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginStart="6dp" />

                <TextView
                    android:id="@+id/btnLeagueInfo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="ⓘ"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2D1B5E"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtCurrentLeague"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌱 Beginner League"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2D1B5E"
                android:gravity="center"
                android:background="@drawable/bg_league_chip"
                android:padding="14dp"
                android:layout_marginTop="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_profile_card"
                    android:elevation="6dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/token_icon"
                        android:textSize="40sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/txtLeagueTokens"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/token_count"
                        android:textColor="#5B2FC4"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="18sp"
                        android:autoSizeMaxTextSize="36sp"
                        android:autoSizeStepGranularity="1sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_profile_card"
                    android:elevation="6dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/star_icon"
                        android:textSize="40sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/txtLeagueStars"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/token_count"
                        android:textColor="#5B2FC4"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="18sp"
                        android:autoSizeMaxTextSize="36sp"
                        android:autoSizeStepGranularity="1sp" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/txtLeagueProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⭐ 0 stars • 100 stars to next league"
                android:textSize="20sp"
                android:textColor="#5B2FC4"
                android:gravity="center"
                android:layout_marginTop="10dp" />

            <ProgressBar
                android:id="@+id/progressLeague"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:max="100"
                android:progress="0"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/txtLeagueBonus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Daily login bonus: +1 token"
                android:textSize="14sp"
                android:textColor="#5B2FC4"
                android:gravity="center"
                android:layout_marginTop="10dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>