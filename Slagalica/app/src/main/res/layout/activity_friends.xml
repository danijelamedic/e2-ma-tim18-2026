<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1FF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="24dp"
        android:paddingBottom="110dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">


                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FRIENDS"
                    android:textColor="#2D1B5E"
                    android:textSize="28sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/btnLogout"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/logout_icon"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="#2D1B5E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="6dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔍 FIND PLAYER"
                    android:textColor="#5A31C8"
                    android:textSize="15sp"
                    android:textStyle="bold|italic"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/searchUsernameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_profile_card"
                    android:hint="Username"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#2D1457"
                    android:textColorHint="#7B61B8"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:inputType="text"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/searchPlayerButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="+ ADD FRIEND"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold|italic"
                    android:background="@drawable/bg_purple_button"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/searchResultTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:visibility="gone"
                    android:textColor="#2D1457"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/cardScanQr"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="▦  SCAN QR CODE"
                android:textColor="#5A31C8"
                android:textSize="16sp"
                android:textStyle="bold|italic"
                android:background="@drawable/bg_profile_card"
                android:elevation="6dp"
                android:layout_marginBottom="18dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👥 MY FRIENDS"
                android:textColor="#5A31C8"
                android:textSize="17sp"
                android:textStyle="bold|italic"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/friendsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvEmptyFriends"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:gravity="center"
                    android:text="No friends yet.\nSearch by username or scan QR code."
                    android:textColor="#6F50B5"
                    android:textSize="14sp"
                    android:textStyle="bold|italic"
                    android:background="@drawable/bg_profile_card"
                    android:elevation="5dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_profile_card"
        android:elevation="12dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🔔"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navFriends"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👥"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navLeaderboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏆"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navStatistics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📊"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👤"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>