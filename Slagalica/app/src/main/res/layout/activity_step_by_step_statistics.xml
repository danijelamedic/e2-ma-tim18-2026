<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/back_icon"
                android:textColor="#2D1B5E"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/step_by_step_statistics_title"
                android:textColor="#2D1B5E"
                android:textSize="24sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_profile_card"
            android:elevation="6dp"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/average_step_by_step_success"
                android:textColor="#5B2FC4"
                android:textSize="20sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvStepByStepSuccess"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/average_step_by_step_points"
                android:textColor="#2D1B5E"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="8dp" />

            <ProgressBar
                android:id="@+id/progressStepByStep"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:progress="48"
                android:max="100"
                android:progressTint="#6A4CAF"
                android:progressBackgroundTint="#E6D8FF"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_profile_card"
            android:elevation="6dp"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step_by_step_steps_title"
                android:textColor="#5B2FC4"
                android:textSize="20sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvStep1Percent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:text="@string/step_by_step_step_1"
                android:textColor="#2D1B5E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp"
                android:layout_marginBottom="7dp" />

            <TextView
                android:id="@+id/tvStep2Percent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:text="@string/step_by_step_step_2"
                android:textColor="#2D1B5E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp"
                android:layout_marginBottom="7dp" />

            <TextView
                android:id="@+id/tvStep3Percent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:text="@string/step_by_step_step_3"
                android:textColor="#2D1B5E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp"
                android:layout_marginBottom="7dp" />

            <TextView
                android:id="@+id/tvStep4Percent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:text="@string/step_by_step_step_4"
                android:textColor="#2D1B5E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp"
                android:layout_marginBottom="7dp" />

            <TextView
                android:id="@+id/tvStep5Percent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:text="@string/step_by_step_step_5"
                android:textColor="#2D1B5E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp"
                android:layout_marginBottom="7dp" />

            <TextView
                android:id="@+id/tvStep6Percent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:text="@string/step_by_step_step_6"
                android:textColor="#2D1B5E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp"
                android:layout_marginBottom="7dp" />

            <TextView
                android:id="@+id/tvStep7Percent"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:text="@string/step_by_step_step_7"
                android:textColor="#2D1B5E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_profile_card"
            android:elevation="6dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/match_statistics_title"
                android:textColor="#5B2FC4"
                android:textSize="20sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvStepByStepGamesPlayed"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:text="@string/total_played_matches"
                android:textColor="#2D1B5E"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStepByStepAverageScore"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:text="@string/win_loss_percentage"
                android:textColor="#2D1B5E"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="@drawable/bg_stat_card"
                android:paddingLeft="14dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>