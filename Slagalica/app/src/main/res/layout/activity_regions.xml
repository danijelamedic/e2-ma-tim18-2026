<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2EAFE">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="24dp"
        android:paddingBottom="110dp"
        android:scrollbars="none"
        android:fadeScrollbars="false">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btnBackRegions"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/back_icon"
                    android:textColor="#2D1B5E"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REGIONS"
                    android:textColor="#2D1B5E"
                    android:textSize="28dp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:padding="12dp"
                android:background="@drawable/bg_profile_card"
                android:elevation="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗺 Serbia map"
                    android:textStyle="bold"
                    android:textColor="#2C1B5A"
                    android:textSize="18sp"/>

                <org.osmdroid.views.MapView
                    android:id="@+id/mapRegions"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardMyRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_profile_card"
                android:elevation="6dp">

                <TextView
                    android:id="@+id/tvMyRegion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 My region: -"
                    android:textColor="#2C1B5A"
                    android:textSize="18sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:id="@+id/tvMyRegionStars"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Monthly stars: 0"
                    android:textColor="#5E35B1"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSimulateRegionCycle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:text="Simulate monthly regional cycle"
                android:textColor="@android:color/white"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black"
                android:background="@drawable/bg_purple_button" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏆 MONTHLY REGIONAL RANKING"
                android:textColor="#5E35B1"
                android:textSize="18sp"
                android:textStyle="bold|italic"
                android:layout_marginBottom="10dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRegions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>