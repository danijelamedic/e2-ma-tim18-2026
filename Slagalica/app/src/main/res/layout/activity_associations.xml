<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/associations_icon"
                android:textColor="#2D1B5E"
                android:textSize="22sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:gravity="center_vertical"
                android:text="@string/associations_game_title"
                android:textColor="#2D1B5E"
                android:textSize="25sp"
                android:textStyle="bold|italic" />

            <TextView
                android:id="@+id/btnAssociationsInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="@string/info_icon"
                android:textColor="#5B2FC4"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLeaveAssociations"
                android:layout_width="92dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_purple_button"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/leave_game"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPlayersCard"
            android:layout_width="match_parent"
            android:layout_height="136dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_profile_card"
            android:baselineAligned="false"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/tvAssociationsPlayerAvatar"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_active_player_avatar"
                    android:contentDescription="Player avatar"
                    android:gravity="center"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/avatar_owl" />

                <TextView
                    android:id="@+id/tvAssociationsPlayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:text="@string/player_you_name"
                    android:textColor="#2D1B5E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssociationsPlayerScore"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="@string/player_you_score"
                    android:textColor="#5B2FC4"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssociationsPlayerInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="🪙0 ⭐0 L0"
                    android:textColor="#5B2FC4"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="104dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAssociationsTimer"
                    android:layout_width="92dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:text="@string/associations_timer"
                    android:textColor="#5B2FC4"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssociationsRound"
                    android:layout_width="92dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/associations_round_short"
                    android:textColor="#5B2FC4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssociationsPoints"
                    android:layout_width="92dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/associations_points_short"
                    android:textColor="#5B2FC4"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/tvAssociationsOpponentAvatar"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_inactive_player_avatar"
                    android:contentDescription="Opponent avatar"
                    android:gravity="center"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/avatar_owl" />

                <TextView
                    android:id="@+id/tvAssociationsOpponentName"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:text="@string/player_opponent_name"
                    android:textColor="#2D1B5E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssociationsOpponentScore"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="@string/player_opponent_score"
                    android:textColor="#5B2FC4"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssociationsOpponentInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="🪙0 ⭐0 L0"
                    android:textColor="#5B2FC4"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAssociationsTurn"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_profile_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/associations_board_title"
                    android:textColor="#5B2FC4"
                    android:textSize="16sp"
                    android:textStyle="bold|italic" />

                <Button
                    android:id="@+id/btnPassAssociations"
                    android:layout_width="76dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_purple_button"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="PASS"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="horizontal">

                <include layout="@layout/item_associations_column_a" />
                <include layout="@layout/item_associations_column_b" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvFinalSolution"
                android:layout_width="230dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_associations_closed"
                android:gravity="center"
                android:text="@string/associations_final_placeholder"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="horizontal">

                <include layout="@layout/item_associations_column_c" />
                <include layout="@layout/item_associations_column_d" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>