<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/img_quiz_banner"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AAFFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="92dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="110dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_title"
                    android:textColor="#2D1B5E"
                    android:textSize="30sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/btnLogout"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/logout_icon"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="#2D1B5E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="8dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvWelcomeUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_welcome_title"
                    android:textColor="#2D1B5E"
                    android:textSize="24sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtHomeStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌱 Beginner League   🪙 0   ⭐ 0"
                    android:textColor="#2E1A66"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_league_chip"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_welcome_subtitle"
                    android:textColor="#5B2FC4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/play"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="18sp"
                    android:background="@drawable/bg_purple_button" />

                <Button
                    android:id="@+id/btnChallenge"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Challenge"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="15sp"
                    android:background="@drawable/bg_purple_button" />

                <Button
                    android:id="@+id/btnTournament"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Tournament"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="15sp"
                    android:background="@drawable/bg_purple_button" />

                <Button
                    android:id="@+id/btnChat"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Regional chat"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="15sp"
                    android:background="@drawable/bg_purple_button" />

                <Button
                    android:id="@+id/btnDailyMissions"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Daily missions"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="15sp"
                    android:background="@drawable/bg_purple_button" />

                <Button
                    android:id="@+id/btnRegions"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Regions"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="15sp"
                    android:background="@drawable/bg_purple_button" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_profile_card"
        android:elevation="12dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🔔"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navFriends"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👥"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navLeaderboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏆"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navStatistics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📊"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👤"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
