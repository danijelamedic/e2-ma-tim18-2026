<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="92dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="110dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_title"
                    android:textColor="#2D1B5E"
                    android:textSize="30sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/btnLogout"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="↪"
                    android:textSize="26sp"
                    android:textColor="#5B2FC4"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="8dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_welcome_title"
                    android:textColor="#2D1B5E"
                    android:textSize="24sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_welcome_subtitle"
                    android:textColor="#5B2FC4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/play"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="18sp"
                    android:background="@drawable/bg_purple_button" />

                <Button
                    android:id="@+id/btnChallenge"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Challenge"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="15sp"
                    android:background="@drawable/bg_purple_button" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="8dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/games_menu_title"
                    android:textColor="#2D1B5E"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Ko zna zna"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="14sp"
                    android:background="@drawable/bg_purple_button"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnMatching"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Spojnice"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="14sp"
                    android:background="@drawable/bg_purple_button"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnAssociations"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Asocijacije"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="14sp"
                    android:background="@drawable/bg_purple_button"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnSkocko"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Skocko"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="14sp"
                    android:background="@drawable/bg_purple_button"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnStepByStep"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Korak po korak"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="14sp"
                    android:background="@drawable/bg_purple_button"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnMyNumber"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Moj broj"
                    android:textColor="@android:color/white"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:textSize="14sp"
                    android:background="@drawable/bg_purple_button" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_profile_card"
        android:elevation="12dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="28sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#5B2FC4"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLeaderboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="28sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6E6A7C"
                android:textStyle="bold"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="28sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6E6A7C"
                android:textStyle="bold"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="28sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6E6A7C"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
