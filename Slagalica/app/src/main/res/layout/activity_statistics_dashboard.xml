<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1FF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="105dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/back_icon"
                    android:textColor="#2D1B5E"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Statistics"
                    android:textColor="#2D1B5E"
                    android:textSize="28sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- OVERALL CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="8dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Overall statistics"
                    android:textColor="#5B2FC4"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvOverallSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#2D1B5E"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <ProgressBar
                    android:id="@+id/progressOverall"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#6A4CAF"
                    android:progressBackgroundTint="#E6D8FF"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:id="@+id/tvPlayedMiniGames"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="Played mini-games: 0"
                    android:textColor="#2D1B5E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvBattles"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="Total battles: 0"
                    android:textColor="#2D1B5E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvWinsLosses"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="Wins: 0   Losses: 0"
                    android:textColor="#2D1B5E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp" />
            </LinearLayout>

            <!-- GAME OVERVIEW CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="8dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Game performance"
                    android:textColor="#5B2FC4"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvQuizPercent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:text="Quiz: 0%"
                    android:textColor="#2D1B5E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvMatchingPercent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:text="Matching: 0%"
                    android:textColor="#2D1B5E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvAssociationsPercent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:text="Associations: 0%"
                    android:textColor="#2D1B5E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSkockoPercent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:text="Skočko: 0%"
                    android:textColor="#2D1B5E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvStepByStepPercent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:text="Step by step: 0%"
                    android:textColor="#2D1B5E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvMyNumberPercent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:text="My number: 0%"
                    android:textColor="#2D1B5E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp" />
            </LinearLayout>

            <!-- HIGHLIGHTS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="8dp"
                android:padding="18dp"
                android:layout_marginBottom="110dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Highlights"
                    android:textColor="#5B2FC4"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvBestGame"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="Best game: -"
                    android:textColor="#2D1B5E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvWeakestGame"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="Needs practice: -"
                    android:textColor="#2D1B5E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_card"
                    android:paddingStart="14dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_profile_card"
        android:elevation="12dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🔔"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navFriends"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👥"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navLeaderboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏆"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navStatistics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📊"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👤"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>