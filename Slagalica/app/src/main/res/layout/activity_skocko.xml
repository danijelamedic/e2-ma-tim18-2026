<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:gravity="center_vertical"
                android:text="@string/skocko_game_title"
                android:textColor="#2D1B5E"
                android:textSize="25sp"
                android:textStyle="bold|italic" />

            <TextView
                android:id="@+id/btnSkockoInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="@string/info_icon"
                android:textColor="#5B2FC4"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLeaveSkocko"
                android:layout_width="92dp"
                android:layout_height="42dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_purple_button"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/leave_game"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="136dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_profile_card"
            android:baselineAligned="false"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/tvSkockoYourAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_active_player_avatar"
                    android:contentDescription="Player avatar"
                    android:gravity="center"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/avatar_owl" />

                <TextView
                    android:id="@+id/tvSkockoPlayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="@string/player_you_name"
                    android:textColor="#2D1B5E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoPlayerScore"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:gravity="center"
                    android:text="@string/player_you_score"
                    android:textColor="#5B2FC4"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoPlayerInfo"
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="🪙0 ⭐0 L0"
                    android:textColor="#5B2FC4"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="104dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSkockoTimer"
                    android:layout_width="92dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:text="@string/skocko_timer"
                    android:textColor="#5B2FC4"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoAttempts"
                    android:layout_width="92dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/skocko_attempts_short"
                    android:textColor="#5B2FC4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoRound"
                    android:layout_width="92dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/skocko_round_short"
                    android:textColor="#5B2FC4"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/tvSkockoOpponentAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_inactive_player_avatar"
                    android:contentDescription="Opponent avatar"
                    android:gravity="center"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/avatar_owl" />

                <TextView
                    android:id="@+id/tvSkockoOpponentName"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="@string/player_opponent_name"
                    android:textColor="#2D1B5E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoOpponentScore"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:gravity="center"
                    android:text="@string/player_opponent_score"
                    android:textColor="#5B2FC4"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoOpponentInfo"
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="🪙0 ⭐0 L0"
                    android:textColor="#5B2FC4"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSkockoMode"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvCurrentGuessHint"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="144dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="7dp"
            android:paddingEnd="10dp"
            android:paddingBottom="7dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentGuessTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/skocko_current_guess_title"
                    android:textColor="#5B2FC4"
                    android:textSize="15sp"
                    android:textStyle="bold|italic" />

                <Button
                    android:id="@+id/btnClearGuess"
                    android:layout_width="74dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_notification_action_secondary"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="@string/skocko_clear_action"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView android:id="@+id/slotGuess1" android:layout_width="30dp" android:layout_height="30dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/slotGuess2" android:layout_width="30dp" android:layout_height="30dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/slotGuess3" android:layout_width="30dp" android:layout_height="30dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/slotGuess4" android:layout_width="30dp" android:layout_height="30dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:layout_marginTop="5dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <TextView android:id="@+id/paletteSymbol1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="@drawable/bg_skocko_palette_item" android:gravity="center" android:text="@string/skocko_symbol_1" android:textColor="#2D1B5E" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/paletteSymbol2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="@drawable/bg_skocko_palette_item" android:gravity="center" android:text="@string/skocko_symbol_2" android:textColor="#2D1B5E" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/paletteSymbol3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="@drawable/bg_skocko_palette_item" android:gravity="center" android:text="@string/skocko_symbol_3" android:textColor="#2D1B5E" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/paletteSymbol4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="@drawable/bg_skocko_palette_item" android:gravity="center" android:text="@string/skocko_symbol_4" android:textColor="#2D1B5E" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/paletteSymbol5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" android:layout_weight="1" android:background="@drawable/bg_skocko_palette_item" android:gravity="center" android:text="@string/skocko_symbol_5" android:textColor="#2D1B5E" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:id="@+id/paletteSymbol6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="3dp" android:layout_weight="1" android:background="@drawable/bg_skocko_palette_item" android:gravity="center" android:text="@string/skocko_symbol_6" android:textColor="#2D1B5E" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSubmitSkocko"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_purple_button"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:includeFontPadding="false"
                android:padding="0dp"
                android:text="@string/skocko_submit"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold|italic" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_profile_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center_vertical"
                android:text="@string/skocko_attempts_board_title"
                android:textColor="#5B2FC4"
                android:textSize="16sp"
                android:textStyle="bold|italic" />

            <include layout="@layout/item_skocko_attempt_row_1" />
            <include layout="@layout/item_skocko_attempt_row_2" />
            <include layout="@layout/item_skocko_attempt_row_3" />
            <include layout="@layout/item_skocko_attempt_row_4" />
            <include layout="@layout/item_skocko_attempt_row_5" />
            <include layout="@layout/item_skocko_attempt_row_6" />

            <TextView
                android:id="@+id/tvBonusRowLabel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone" />

            <include layout="@layout/item_skocko_bonus_row" />

            <TextView
                android:id="@+id/tvSolutionRowLabel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone" />

            <include layout="@layout/item_skocko_solution_row" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
