<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:text="@string/skocko_game_title"
                android:textColor="#2D1B5E"
                android:textSize="30sp"
                android:textStyle="bold|italic" />

            <TextView
                android:id="@+id/btnSkockoInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="@string/info_icon"
                android:textColor="#5B2FC4"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLeaveSkocko"
                android:layout_width="96dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_purple_button"
                android:text="@string/leave_game"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvSkockoTimer"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:text="@string/skocko_timer"
                android:textColor="#5B2FC4"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSkockoYourAvatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_active_player_avatar"
                        android:gravity="center"
                        android:text="@string/avatar_icon"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/player_you_name"
                        android:textColor="#2D1B5E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSkockoPlayerScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/player_you_score"
                        android:textColor="#5B2FC4"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:text="@string/vs_label"
                    android:textColor="#5B2FC4"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSkockoOpponentAvatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_inactive_player_avatar"
                        android:gravity="center"
                        android:text="@string/opponent_avatar_icon"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/player_opponent_name"
                        android:textColor="#2D1B5E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSkockoOpponentScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/player_opponent_score"
                        android:textColor="#5B2FC4"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSkockoRound"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/skocko_round_short"
                    android:textColor="#5B2FC4"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoAttempts"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/skocko_attempts_short"
                    android:textColor="#5B2FC4"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/skocko_tokens_short"
                    android:textColor="#5B2FC4"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/skocko_stars_short"
                    android:textColor="#5B2FC4"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_small_pill"
                    android:gravity="center"
                    android:text="@string/skocko_league_short"
                    android:textColor="#5B2FC4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSkockoMode"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_small_pill"
                android:gravity="center"
                android:text="@string/skocko_mode_your_turn"
                android:textColor="#5B2FC4"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/skocko_secret_title"
                android:textColor="#5B2FC4"
                android:textSize="20sp"
                android:textStyle="bold|italic" />

            <TextView
                android:id="@+id/tvCurrentGuessHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/skocko_current_guess_hint"
                android:textColor="#5B2FC4"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/skocko_current_guess_title"
                    android:textColor="#5B2FC4"
                    android:textSize="20sp"
                    android:textStyle="bold|italic" />

                <Button
                    android:id="@+id/btnClearGuess"
                    android:layout_width="96dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_notification_action_secondary"
                    android:text="@string/skocko_clear_action"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/slotGuess1"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/slotGuess2"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/slotGuess3"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/slotGuess4"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_skocko_slot_empty"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#5B2FC4"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/paletteSymbol1"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skocko_palette_item"
                    android:gravity="center"
                    android:text="@string/skocko_symbol_1"
                    android:textColor="#2D1B5E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/paletteSymbol2"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skocko_palette_item"
                    android:gravity="center"
                    android:text="@string/skocko_symbol_2"
                    android:textColor="#2D1B5E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/paletteSymbol3"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skocko_palette_item"
                    android:gravity="center"
                    android:text="@string/skocko_symbol_3"
                    android:textColor="#2D1B5E"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/paletteSymbol4"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skocko_palette_item"
                    android:gravity="center"
                    android:text="@string/skocko_symbol_4"
                    android:textColor="#2D1B5E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/paletteSymbol5"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skocko_palette_item"
                    android:gravity="center"
                    android:text="@string/skocko_symbol_5"
                    android:textColor="#2D1B5E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/paletteSymbol6"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skocko_palette_item"
                    android:gravity="center"
                    android:text="@string/skocko_symbol_6"
                    android:textColor="#2D1B5E"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSubmitSkocko"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_purple_button"
                android:fontFamily="sans-serif-black"
                android:text="@string/skocko_submit"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold|italic" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/skocko_attempts_board_title"
                android:textColor="#5B2FC4"
                android:textSize="20sp"
                android:textStyle="bold|italic" />

            <include layout="@layout/item_skocko_attempt_row_1" />
            <include layout="@layout/item_skocko_attempt_row_2" />
            <include layout="@layout/item_skocko_attempt_row_3" />
            <include layout="@layout/item_skocko_attempt_row_4" />
            <include layout="@layout/item_skocko_attempt_row_5" />
            <include layout="@layout/item_skocko_attempt_row_6" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:background="#DCCEFF" />

            <TextView
                android:id="@+id/tvBonusRowLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/skocko_bonus_row_title"
                android:textColor="#5B2FC4"
                android:textSize="15sp"
                android:textStyle="bold" />

            <include layout="@layout/item_skocko_bonus_row" />

            <TextView
                android:id="@+id/tvSolutionRowLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:text="@string/skocko_solution_row_title"
                android:textColor="#5B2FC4"
                android:textSize="15sp"
                android:textStyle="bold" />

            <include layout="@layout/item_skocko_solution_row" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
