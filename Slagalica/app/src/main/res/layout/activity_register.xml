<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/register"
                android:textColor="#2D1B5E"
                android:textSize="32sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join the battle. Create your account."
                android:textColor="#8B6FBF"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@drawable/bg_accent_line" />

        </LinearLayout>

        <!-- FORM CARD -->
        <LinearLayout
            android:id="@+id/layoutFormCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_premium"
            android:elevation="12dp"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <!-- EMAIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="#5B2FC4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:textColor="#1E0A3C"
                android:textColorHint="#A89CC8"
                android:textSize="15sp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp" />

            <!-- USERNAME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USERNAME"
                android:textColor="#5B2FC4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_username"
                android:textColor="#1E0A3C"
                android:textColorHint="#A89CC8"
                android:textSize="15sp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp" />

            <!-- PASSWORD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="#5B2FC4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textColor="#1E0A3C"
                android:textColorHint="#A89CC8"
                android:textSize="15sp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp" />

            <!-- CONFIRM PASSWORD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRM PASSWORD"
                android:textColor="#5B2FC4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etPasswordConfirm"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_confirm_password"
                android:inputType="textPassword"
                android:textColor="#1E0A3C"
                android:textColorHint="#A89CC8"
                android:textSize="15sp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp" />

            <!-- REGION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REGION"
                android:textColor="#5B2FC4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etRegion"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_region"
                android:textColor="#1E0A3C"
                android:textColorHint="#A89CC8"
                android:textSize="15sp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="28dp" />

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/register"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textSize="16sp"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_button_selector"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>