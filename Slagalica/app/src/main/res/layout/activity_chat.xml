<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_profile_screen">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Region Chat"
        android:textSize="22sp"
        android:textColor="#2D1B5E"
        android:textStyle="bold"
        android:padding="16dp"
        android:background="@drawable/bg_card_premium"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/messagesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@drawable/bg_card_premium">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:background="@drawable/bg_input_selector"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#1E0A3C"
            android:textColorHint="#A89CC8"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Send"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_button_selector"/>

    </LinearLayout>

</LinearLayout>