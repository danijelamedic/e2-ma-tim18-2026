<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4ECFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="20dp"
        android:paddingBottom="104dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/back_icon"
                    android:textColor="#2D1B5E"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LEADERBOARD"
                    android:textColor="#2D1B5E"
                    android:textSize="26sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginStart="6dp" />

                <TextView
                    android:id="@+id/btnRankingInfo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/info_icon"
                    android:textColor="#2D1B5E"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_profile_card"
                android:elevation="6dp"
                android:padding="6dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tabWeekly"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="WEEKLY"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_notification_filter_active" />

                <TextView
                    android:id="@+id/tabMonthly"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="MONTHLY"
                    android:textColor="#5B2FC4"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_notification_filter_inactive"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCycleLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cycle"
                android:textColor="#2E1A66"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_league_chip"
                android:padding="10dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvPlayerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌱 Beginner League   🪙 0   ⭐ 0"
                android:textColor="#2E1A66"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_league_chip"
                android:padding="10dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/currentPlayerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:elevation="6dp"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvCurrentPlayerRank"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your placement will appear after one ranked match."
                    android:textColor="#2D1B5E"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RANKED PLAYERS"
                android:textColor="#5B2FC4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/leaderboardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvEmptyLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No ranked matches in this cycle yet."
                android:textColor="#5B2FC4"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="18dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_profile_card"
        android:elevation="12dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🔔"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/navFriends"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👥"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/navLeaderboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏆"
            android:textSize="28sp"
            android:background="@drawable/bg_league_chip" />

        <TextView
            android:id="@+id/navStatistics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📊"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👤"
            android:textSize="24sp" />

    </LinearLayout>
</FrameLayout>
