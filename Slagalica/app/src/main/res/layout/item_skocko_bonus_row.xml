<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rowBonusAttempt"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_stat_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView android:id="@+id/bonusSlot1" android:layout_width="38dp" android:layout_height="38dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
        <TextView android:id="@+id/bonusSlot2" android:layout_width="38dp" android:layout_height="38dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
        <TextView android:id="@+id/bonusSlot3" android:layout_width="38dp" android:layout_height="38dp" android:layout_marginEnd="6dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
        <TextView android:id="@+id/bonusSlot4" android:layout_width="38dp" android:layout_height="38dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="56dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView android:id="@+id/bonusFeedback1" android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="2dp" android:background="@drawable/bg_skocko_feedback_empty" />
        <TextView android:id="@+id/bonusFeedback2" android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="2dp" android:background="@drawable/bg_skocko_feedback_empty" />
        <TextView android:id="@+id/bonusFeedback3" android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="2dp" android:background="@drawable/bg_skocko_feedback_empty" />
        <TextView android:id="@+id/bonusFeedback4" android:layout_width="10dp" android:layout_height="10dp" android:layout_margin="2dp" android:background="@drawable/bg_skocko_feedback_empty" />
    </LinearLayout>
</LinearLayout>
