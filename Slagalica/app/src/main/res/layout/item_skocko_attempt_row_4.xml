<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="5dp"
    android:background="@drawable/bg_stat_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="5dp">

    <TextView
        android:layout_width="28dp"
        android:layout_height="34dp"
        android:gravity="center"
        android:text="@string/skocko_attempt_row_4"
        android:textColor="#5B2FC4"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView android:id="@+id/attempt4Slot1" android:layout_width="31dp" android:layout_height="31dp" android:layout_marginEnd="4dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
        <TextView android:id="@+id/attempt4Slot2" android:layout_width="31dp" android:layout_height="31dp" android:layout_marginEnd="4dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
        <TextView android:id="@+id/attempt4Slot3" android:layout_width="31dp" android:layout_height="31dp" android:layout_marginEnd="4dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
        <TextView android:id="@+id/attempt4Slot4" android:layout_width="31dp" android:layout_height="31dp" android:background="@drawable/bg_skocko_slot_empty" android:gravity="center" android:text="?" android:textColor="#5B2FC4" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="44dp"
        android:layout_height="34dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView android:id="@+id/attempt4Feedback1" android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@drawable/bg_skocko_feedback_empty" />
        <TextView android:id="@+id/attempt4Feedback2" android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@drawable/bg_skocko_feedback_empty" />
        <TextView android:id="@+id/attempt4Feedback3" android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@drawable/bg_skocko_feedback_empty" />
        <TextView android:id="@+id/attempt4Feedback4" android:layout_width="8dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@drawable/bg_skocko_feedback_empty" />
    </LinearLayout>
</LinearLayout>
